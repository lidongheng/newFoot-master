#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/babylon@6.18.0/node_modules/babylon/bin/node_modules:/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/babylon@6.18.0/node_modules/babylon/node_modules:/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/babylon@6.18.0/node_modules:/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/babylon@6.18.0/node_modules/babylon/bin/node_modules:/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/babylon@6.18.0/node_modules/babylon/node_modules:/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/babylon@6.18.0/node_modules:/Users/donghengli/Desktop/www/newFoot-master/manager-server/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../babylon/bin/babylon.js" "$@"
else
  exec node  "$basedir/../babylon/bin/babylon.js" "$@"
fi
