{
  "name": "cup-analyzer-crawler-server",
  "version": "1.0.0",
  "description": "杯赛数据爬虫服务（世界杯 / 欧冠等）- Koa2",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "crawl:squad": "node crawlers/squadCrawler.js",
    "crawl:squad:one": "node crawlers/squadCrawler.js --team",
    "crawl:match": "node crawlers/matchDataCrawler.js",
    "process:squad": "node processors/squadProcessor.js",
    "process:squad:one": "node processors/squadProcessor.js --team",
    "process:squad-final:init": "node processors/squadFinalInitializer.js",
    "process:squad-final:init:one": "node processors/squadFinalInitializer.js --team",
    "process:profile": "node processors/teamProfileGenerator.js",
    "process:profile:one": "node processors/teamProfileGenerator.js --team",
    "process:league-squad": "node processors/leagueSquadProcessor.js",
    "crawl:schedule:ucl": "cross-env CUP_ANALYZER_CUP=championsLeague node crawlers/scheduleCrawler.js",
    "crawl:schedule:epl": "cross-env CUP_ANALYZER_CUP=epl node crawlers/scheduleCrawler.js",
    "crawl:schedule:kleague": "cross-env CUP_ANALYZER_CUP=koreanKLeague node crawlers/scheduleCrawler.js",
    "crawl:schedule:aleague": "cross-env CUP_ANALYZER_CUP=aLeague node crawlers/scheduleCrawler.js",
    "crawl:schedule:mls": "cross-env CUP_ANALYZER_CUP=mls node crawlers/scheduleCrawler.js",
    "crawl:schedule:seriea": "cross-env CUP_ANALYZER_CUP=serieA node crawlers/scheduleCrawler.js",
    "crawl:player-list": "node crawlers/playerListCrawler.js",
    "crawl:player-list:club": "node crawlers/playerListCrawler.js --with-club",
    "analyze:club-domestic": "node analyzers/clubMatchAnalyzer.js",
    "generate:match-squad": "node processors/matchSquadGenerator.js",
    "generate:cycle-report": "node processors/cycleReportGenerator.js"
  },
  "keywords": ["world-cup", "champions-league", "crawler", "football"],
  "author": "donghengli",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "iconv-lite": "^0.6.3",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^12.0.1",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10"
  }
}
